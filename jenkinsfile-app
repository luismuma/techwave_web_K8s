pipeline {
    agent any
    stages {
        stage('Execute deploy flask-app') {
            steps {
                sh '''
                    PATH_APP_ARGO="argoCD/argo-application.yaml"
                    HELM_PATH="helm/flask-app"
                    NAMESPACE="${2:-flask-app}"    # Namespace opcional
                    echo "📦 Desplegando app Flask con Helm..."
                    kubectl create namespace "$NAMESPACE" --dry-run=client -o yaml | kubectl apply -f -
                    helm upgrade --install flask-app "$HELM_PATH" -f "$HELM_PATH/values-green.yaml" --namespace "$NAMESPACE"
                    echo "✅ App Flask desplegada correctamente"

                    sleep 25
                    kubectl apply -f "$PATH_APP_ARGO"
                    sleep 10
                '''
            }
        }

        stage('Register Application in Argo CD') {
            steps {
                sh '''
                    PATH_APP_ARGO="argoCD/argo-application.yaml"
                    APP_NAME="techwave-web"

                    echo "🚀 Aplicando Application de Argo CD..."
                    kubectl apply -f "$PATH_APP_ARGO"

                    echo "⏳ Sincronizando aplicación en Argo CD..."
                    argocd app sync "$APP_NAME" --prune --timeout 300 --retry-limit 3 --self-heal

                    echo "🔍 Esperando a que la aplicación esté Healthy y Synced..."
                    argocd app wait "$APP_NAME" --health --timeout 300

                    echo "✅ Aplicación registrada y gestionada por Argo CD"
                '''
            }
        }
    }
    post {
        success {
            echo "🎉 Pipeline completado correctamente."
        }
        cleanup {
            cleanWs()
        }
    }
}
