pipeline {
    agent any
    environment {
        COMPOSE_FILE = "observability/docker-compose.yml"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Verificar Docker') {
            steps {
                sh 'docker --version'
                sh 'docker compose version || docker-compose --version'
            }
        }
        stage('Levantar Observability Stack') {
            steps {
                sh """
                docker compose -f ${COMPOSE_FILE} up -d || docker-compose -f ${COMPOSE_FILE} up -d
                """
            }
        }
        stage('Verificar Contenedores') {
            steps {
                sh 'docker ps'
            }
        }
    }

    post {
        always {
            echo 'Pipeline finalizado'
        }
        success {
            echo 'Observability stack levantado correctamente 🚀'
        }
        failure {
            echo 'Error al levantar el stack ❌'
        }
    }
}
