pipeline {
    agent any
    environment {
        COMPOSE_FILE = "observability/local/docker-compose.yml"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Stop docker container'){
            steps {
                sh 'docker compose -f observability/local/docker-compose.yml down'
            }
        }
        stage('Verificar Docker') {
            steps {
                sh 'docker --version'
                sh 'docker compose version'
            }
        }

        stage('Preparar Loki dirs') {
            steps {
                sh """
                mkdir -p loki/wal loki/index loki/chunks
                chmod -R 777 loki
                """
            }
        }
        stage('Restart Stack') {
            steps {
                sh """
                docker compose -f ${COMPOSE_FILE} down
                docker compose -f ${COMPOSE_FILE} up -d --build
                """
            }
        }
        stage('Verificar Contenedores') {
            steps {
                sh 'docker ps'
            }
        }
    }

    post {
        always {
            echo 'Pipeline finalizado'
        }
        success {
            echo 'Observability stack levantado correctamente 🚀'
        }
        failure {
            echo 'Error al levantar el stack ❌'
        }
    }
}
